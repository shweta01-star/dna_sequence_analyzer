# ---------- IMPORTS ----------
from collections import Counter
import matplotlib.pyplot as plt
import matplotlib.patches as mpatches

# =====================================================
# SECTION 1: VALIDATION
# =====================================================

def _validate_dna_sequence(dna_sequence):
    """
    Validates if a sequence contains only valid DNA characters (A, T, C, G).
    Raises ValueError if invalid characters are found.
    """
    if not dna_sequence:
        raise ValueError("DNA sequence cannot be empty.")
    valid_chars = set('ATCGatcg')
    invalid = [ch for ch in dna_sequence if ch not in valid_chars]
    if invalid:
        raise ValueError(f"Invalid DNA sequence: found invalid characters {set(invalid)}. Only A, T, C, G allowed.")


# =====================================================
# SECTION 2: CORE FUNCTIONS
# =====================================================

def calculate_gc_content(dna_sequence):
    """
    Calculates the GC content (%) of a DNA sequence.
    GC content is important in drug design — higher GC = more stable DNA duplex.
    Relevant in: antisense oligonucleotide design, PCR primer stability.
    """
    _validate_dna_sequence(dna_sequence)
    dna_sequence = dna_sequence.upper()
    gc_count = dna_sequence.count("G") + dna_sequence.count("C")
    return round((gc_count / len(dna_sequence)) * 100, 2)


def transcribe_dna_to_rna(dna_sequence):
    """
    Transcribes a DNA sequence to RNA (replaces Thymine with Uracil).
    This mimics the first step of gene expression inside a cell.
    Relevant in: mRNA vaccine design, gene therapy.
    """
    _validate_dna_sequence(dna_sequence)
    return dna_sequence.upper().replace("T", "U")


def reverse_complement(dna_sequence):
    """
    Generates the reverse complement of a DNA sequence.
    DNA is double-stranded and antiparallel — this gives you the other strand
    read in the correct 5' to 3' direction.
    Relevant in: PCR primer design, antisense drug design (e.g., Fomivirsen).
    """
    _validate_dna_sequence(dna_sequence)
    complement_map = {
        'A': 'T', 'T': 'A', 'C': 'G', 'G': 'C',
        'a': 't', 't': 'a', 'c': 'g', 'g': 'c'
    }
    complement_seq = "".join([complement_map[base] for base in dna_sequence])
    return complement_seq[::-1]


def get_complementary_dna(dna_sequence):
    """
    Generates the complementary strand WITHOUT reversing it.
    Gives you the direct base-pair partner of each nucleotide.
    """
    _validate_dna_sequence(dna_sequence)
    complement_map = {
        'A': 'T', 'T': 'A', 'C': 'G', 'G': 'C',
        'a': 't', 't': 'a', 'c': 'g', 'g': 'c'
    }
    return "".join([complement_map[base] for base in dna_sequence])


def translate_rna_to_protein(rna_sequence):
    """
    Translates an RNA sequence into an amino acid (protein) sequence using the genetic code.
    Stops at stop codons (UAA, UAG, UGA).
    Relevant in: target protein identification, drug target validation.
    """
    genetic_code = {
        'UUU': 'F', 'UUC': 'F', 'UUA': 'L', 'UUG': 'L',
        'CUU': 'L', 'CUC': 'L', 'CUA': 'L', 'CUG': 'L',
        'AUU': 'I', 'AUC': 'I', 'AUA': 'I', 'AUG': 'M',
        'GUU': 'V', 'GUC': 'V', 'GUA': 'V', 'GUG': 'V',
        'UCU': 'S', 'UCC': 'S', 'UCA': 'S', 'UCG': 'S',
        'CCU': 'P', 'CCC': 'P', 'CCA': 'P', 'CCG': 'P',
        'ACU': 'T', 'ACC': 'T', 'ACA': 'T', 'ACG': 'T',
        'GCU': 'A', 'GCC': 'A', 'GCA': 'A', 'GCG': 'A',
        'UAU': 'Y', 'UAC': 'Y', 'UAA': '*', 'UAG': '*',
        'CAU': 'H', 'CAC': 'H', 'CAA': 'Q', 'CAG': 'Q',
        'AAU': 'N', 'AAC': 'N', 'AAA': 'K', 'AAG': 'K',
        'GAU': 'D', 'GAC': 'D', 'GAA': 'E', 'GAG': 'E',
        'UGU': 'C', 'UGC': 'C', 'UGA': '*', 'UGG': 'W',
        'CGU': 'R', 'CGC': 'R', 'CGA': 'R', 'CGG': 'R',
        'AGU': 'S', 'AGC': 'S', 'AGA': 'R', 'AGG': 'R',
        'GGU': 'G', 'GGC': 'G', 'GGA': 'G', 'GGG': 'G'
    }
    rna_sequence = rna_sequence.upper()
    protein_sequence = []
    for i in range(0, len(rna_sequence) - len(rna_sequence) % 3, 3):
        codon = rna_sequence[i:i+3]
        amino_acid = genetic_code.get(codon, 'X')
        if amino_acid == '*':
            break
        protein_sequence.append(amino_acid)
    return "".join(protein_sequence)


def find_dna_motifs(dna_sequence, motif):
    """
    Finds all positions (1-based index) where a motif appears in the DNA sequence.
    Relevant in: restriction enzyme site identification, promoter analysis.
    """
    _validate_dna_sequence(dna_sequence)
    dna_sequence = dna_sequence.upper()
    motif = motif.upper()
    indices = []
    for i in range(len(dna_sequence) - len(motif) + 1):
        if dna_sequence[i:i+len(motif)] == motif:
            indices.append(i + 1)  # 1-based indexing (biology convention)
    return indices


def find_common_substrings(seq1, seq2, min_length=3):
    """
    Finds common substrings of a minimum length between two DNA sequences.
    Useful for identifying conserved regions across species or gene variants.
    """
    seq1, seq2 = seq1.upper(), seq2.upper()
    common_subs = set()
    for i in range(len(seq1)):
        for j in range(len(seq2)):
            k = 0
            while (i + k < len(seq1) and j + k < len(seq2) and
                   seq1[i + k] == seq2[j + k]):
                k += 1
            if k >= min_length:
                common_subs.add(seq1[i:i+k])
    return sorted(list(common_subs))


def nucleotide_frequency(dna_sequence):
    """
    Counts the frequency of each nucleotide (A, T, C, G) in the sequence.
    """
    _validate_dna_sequence(dna_sequence)
    dna_sequence = dna_sequence.upper()
    freq = Counter(dna_sequence)
    return {base: freq.get(base, 0) for base in ['A', 'T', 'C', 'G']}


# =====================================================
# SECTION 3: VISUALIZATION
# =====================================================

def plot_nucleotide_frequency(dna_sequence):
    """
    Plots a bar chart of nucleotide frequencies in the DNA sequence.
    Visual output — useful for quick sequence composition analysis.
    """
    freq = nucleotide_frequency(dna_sequence)
    colors = ['#4CAF50', '#F44336', '#2196F3', '#FF9800']  # A=green, T=red, C=blue, G=orange
    bases = list(freq.keys())
    counts = list(freq.values())

    plt.figure(figsize=(7, 5))
    bars = plt.bar(bases, counts, color=colors, edgecolor='black', width=0.5)

    for bar, count in zip(bars, counts):
        plt.text(bar.get_x() + bar.get_width()/2, bar.get_height() + 0.2,
                 str(count), ha='center', va='bottom', fontweight='bold')

    plt.title(f'Nucleotide Frequency\n(GC Content: {calculate_gc_content(dna_sequence)}%)',
              fontsize=13, fontweight='bold')
    plt.xlabel('Nucleotide Base', fontsize=11)
    plt.ylabel('Count', fontsize=11)
    plt.ylim(0, max(counts) + 2)

    legend_patches = [mpatches.Patch(color=colors[i], label=bases[i]) for i in range(4)]
    plt.legend(handles=legend_patches, title='Bases')
    plt.tight_layout()
    plt.savefig('nucleotide_frequency.png', dpi=150)
    plt.show()
    print("Plot saved as nucleotide_frequency.png")


def plot_gc_content_window(dna_sequence, window_size=5):
    """
    Plots GC content across the sequence using a sliding window.
    Useful for identifying GC-rich regions — important in promoter analysis
    and antisense oligonucleotide target selection.
    """
    dna_sequence = dna_sequence.upper()
    gc_values = []
    positions = []

    for i in range(len(dna_sequence) - window_size + 1):
        window = dna_sequence[i:i+window_size]
        gc = (window.count('G') + window.count('C')) / window_size * 100
        gc_values.append(gc)
        positions.append(i + 1)

    plt.figure(figsize=(10, 4))
    plt.plot(positions, gc_values, color='#9C27B0', linewidth=2, marker='o', markersize=4)
    plt.axhline(y=50, color='red', linestyle='--', alpha=0.5, label='50% GC line')
    plt.fill_between(positions, gc_values, alpha=0.15, color='#9C27B0')
    plt.title(f'GC Content Across Sequence (Window Size = {window_size})',
              fontsize=13, fontweight='bold')
    plt.xlabel('Position', fontsize=11)
    plt.ylabel('GC Content (%)', fontsize=11)
    plt.legend()
    plt.tight_layout()
    plt.savefig('gc_content_window.png', dpi=150)
    plt.show()
    print("Plot saved as gc_content_window.png")


# =====================================================
# SECTION 4: FULL ANALYSIS REPORT
# =====================================================

def full_analysis(dna_sequence, motif=None):
    """
    Runs a complete analysis on a given DNA sequence and prints a clean report.
    """
    print("=" * 55)
    print("       DNA SEQUENCE ANALYSER — FULL REPORT")
    print("       MPharm Pharmaceutics | RGHUS Bengaluru")
    print("=" * 55)

    _validate_dna_sequence(dna_sequence)
    dna_sequence = dna_sequence.upper()

    print(f"\n INPUT SEQUENCE     : {dna_sequence}")
    print(f" Length             : {len(dna_sequence)} bp")
    print(f" GC Content         : {calculate_gc_content(dna_sequence)}%")

    freq = nucleotide_frequency(dna_sequence)
    print(f"\n NUCLEOTIDE COUNTS  : A={freq['A']}  T={freq['T']}  C={freq['C']}  G={freq['G']}")

    comp = get_complementary_dna(dna_sequence)
    rev_comp = reverse_complement(dna_sequence)
    rna = transcribe_dna_to_rna(dna_sequence)
    protein = translate_rna_to_protein(rna)

    print(f"\n COMPLEMENTARY DNA  : {comp}")
    print(f" REVERSE COMPLEMENT : {rev_comp}")
    print(f" RNA TRANSCRIPT     : {rna}")
    print(f" PROTEIN SEQUENCE   : {protein}")

    if motif:
        positions = find_dna_motifs(dna_sequence, motif)
        print(f"\n MOTIF SEARCH '{motif}' : Found at positions {positions if positions else 'Not found'}")

    print("\n" + "=" * 55)
    print(" Generating visualizations...")
    plot_nucleotide_frequency(dna_sequence)
    plot_gc_content_window(dna_sequence)
    print("=" * 55)


# =====================================================
# SECTION 5: RUN
# =====================================================

if __name__ == "__main__":
    sample_dna = "ATGCGATACGCTTGACGTACGATCGATCGGCTA"
    full_analysis(sample_dna, motif="CGA")
